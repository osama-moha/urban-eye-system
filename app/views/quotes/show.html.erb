<% if current_system_admin %>
  <div class="container mt-5 mb-5">
    <div class="alert alert-info d-print-none text-center">
      <i class="bi bi-shield-lock-fill"></i> <strong>Admin Mode:</strong> You are seeing the full breakdown. Customers will only see the "Locked" version.
    </div>

    <div class="card shadow-lg border-0" style="max-width: 850px; margin: auto; position: relative; overflow: hidden;">
      
      <div class="pdf-watermark">
        <%= image_tag "logo.png" %>
      </div>

      <div class="quote-header" style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #eaeaea; padding: 40px 40px 20px 40px; position: relative; z-index: 2; background: white;">
        <div style="flex: 0 0 250px;">
          <%= image_tag "logo.png", class: "brand-logo", style: "width: 100%; height: auto; display: block;" %>
        </div>

        <div style="flex: 1; text-align: right; padding-left: 20px;">
          <h1 class="doc-title" style="color: #003366; font-weight: 800; font-size: 32px; margin: 0 0 10px 0; text-transform: uppercase;">
            <%= @quote.total_amount.to_i == 0 ? "Service Request" : "Quotation" %>
          </h1>
          <table style="float: right; text-align: right; font-size: 14px;">
            <tr>
              <td style="color: #666; padding-right: 10px;">Date:</td>
              <td style="font-weight: bold; color: #000;"><%= @quote.created_at.strftime("%d/%m/%Y") %></td>
            </tr>
            <tr>
              <td style="color: #666; padding-right: 10px;">Ref #:</td>
              <td style="font-weight: bold; color: #000;">UES/2025/QT-<%= @quote.id.to_s.rjust(4, '0') %></td>
            </tr>
            <tr>
              <td style="color: #666; padding-right: 10px;">To:</td>
              <td style="font-weight: bold; color: #000;"><%= @quote.email.presence || @quote.lead.name %></td>
            </tr>
          </table>
        </div>
      </div>

      <div class="card-body p-5" style="position: relative; z-index: 1;">
        
        <% if @quote.total_amount.to_i == 0 %>
           <div class="alert alert-primary border-0 p-4 mb-4">
             <h4 class="fw-bold"><i class="bi bi-shield-shaded"></i> Manned Guarding Request</h4>
             <p class="mb-0"><%= @quote.purpose %></p>
             <hr>
             <p class="small mb-0"><strong>Status:</strong> Pending Site Survey & Risk Assessment.</p>
           </div>
        <% else %>
           <div class="row mb-4">
             <div class="col-md-12">
               <div class="alert alert-light border-start border-5 border-primary shadow-sm p-4" style="border-color: #003366 !important;">
                 <div class="d-flex justify-content-between align-items-center">
                   <div>
                     <h5 class="fw-bold mb-1" style="color: #003366;">
                       <i class="bi bi-shield-check text-success"></i> Peace of Mind Investment
                     </h5>
                     <p class="text-muted mb-0 small">Based on a 1-year operational cycle:</p>
                   </div>
                   <div class="text-end">
                     <h2 class="text-success fw-bold mb-0">
                       KES <%= number_with_delimiter((@quote.total_amount.to_i / 365).to_i) %>/day
                     </h2>
                     <span class="badge bg-success bg-opacity-10 text-success">Less than lunch</span>
                   </div>
                 </div>
               </div>
             </div>
           </div>
        <% end %>

        <div class="mt-4 mb-4">
          <h6 class="fw-bold text-uppercase border-bottom pb-2" style="color: #003366;">
            <i class="bi bi-geo-alt-fill"></i> Site-Specific Strategy: <%= @quote.building_type %>
          </h6>
          <div class="bg-white p-3 border rounded">
            <p class="small text-muted mb-2">Location: <strong><%= @quote.location.presence || "Nairobi" %></strong></p>
            <p class="small mb-0">System/Service designed for <%= @quote.building_type %> security protocols.</p>
          </div>
        </div>
        
        <% if @quote.total_amount.to_i > 0 %>
          <div class="text-center mb-4">
            <h5 class="fw-bold bg-light p-2 border rounded">
              <%= @quote.camera_count %>-CAMERA SYSTEM (SUPPLY & INSTALL)
            </h5>
          </div>

          <table class="table table-bordered align-middle" style="background: transparent !important;">
            <thead class="table-dark text-center">
              <tr>
                <th scope="col" style="width: 55%;">Item Description</th>
                <th scope="col" style="width: 15%;">Qty</th>
                <th scope="col" style="width: 30%;">Total (KES)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <strong>Hikvision Turbo HD Hardware Kit</strong>
                  <ul class="small text-muted mb-0 mt-1 ps-3">
                    <li><%= @quote.camera_count %>x Hikvision HD Cameras</li>
                    <li>DVR + <%= @quote.recording_days %>-Day Storage</li>
                    <% if @quote.monitor? %><li>Monitor included</li><% end %>
                  </ul>
                </td>
                <td class="text-center">1 Set</td>
                <td class="text-end fw-bold"><%= number_to_currency((@quote.total_amount * 0.75), unit: "", precision: 0) %></td>
              </tr>
              <tr>
                <td><strong>Cabling & Infrastructure</strong></td>
                <td class="text-center">1 Lot</td>
                <td class="text-end fw-bold"><%= number_to_currency((@quote.total_amount * 0.10), unit: "", precision: 0) %></td>
              </tr>
              <tr>
                <td><strong>Labor & Configuration</strong></td>
                <td class="text-center">1 Lot</td>
                <td class="text-end fw-bold"><%= number_to_currency((@quote.total_amount * 0.15), unit: "", precision: 0) %></td>
              </tr>
              <tr style="border-top: 3px solid #000;">
                <td colspan="3" style="padding: 0;">
                  <div class="print-color" style="background-color: #003366 !important; -webkit-print-color-adjust: exact; color: white; padding: 20px; display: flex; justify-content: center; align-items: center; gap: 20px;">
                    <span style="font-size: 18px; text-transform: uppercase;">Grand Total (KES):</span>
                    <span style="font-size: 32px; font-weight: 800;">
                      <%= number_to_currency(@quote.total_amount, unit: "KES ", precision: 0) %>
                    </span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        <% end %>

        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-5 d-print-none">
          <button onclick="window.print()" class="btn btn-dark btn-lg px-4">
            <i class="bi bi-printer"></i> Print / Save PDF
          </button>
        </div>

      </div>
    </div>
  </div>

<% else %>
  
  <% if @quote.total_amount.to_i == 0 %>
    
    <div class="container mt-5 mb-5">
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card shadow border-0 text-center p-5">
            <div class="mb-4 text-success">
              <i class="bi bi-check-circle-fill display-1"></i>
            </div>
            <h2 class="fw-bold mb-3">Request Received!</h2>
            <p class="text-muted lead">
              Thank you, <strong><%= @quote.lead.name %></strong>. We have received your request for:
            </p>
            <div class="alert alert-light border border-secondary fw-bold text-dark mx-auto" style="max-width: 400px;">
              <%= @quote.purpose %>
            </div>
            
            <div class="alert alert-info border-0 mt-4 text-start">
              <div class="d-flex">
                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                <div>
                  <strong>What happens next?</strong>
                  <p class="mb-0 small">
                    Security guarding requires a site visit to quote accurately. Our Operations Manager will call you shortly on <strong><%= @quote.lead.phone %></strong> to schedule your free Risk Assessment.
                  </p>
                </div>
              </div>
            </div>

            <div class="mt-4">
              <%= link_to "Return to Home", root_path, class: "btn btn-outline-dark" %>
            </div>
          </div>
        </div>
      </div>
    </div>

  <% else %>
    
    <div class="container my-5">
      
      <div class="text-center mb-5">
        <h5 class="text-muted text-uppercase ls-2">Estimated Investment</h5>
        <h1 class="text-success display-3 fw-bold my-3">
          <%= number_to_currency(@quote.total_amount, unit: "KES ", precision: 0) %>
        </h1>
        
        <% if @quote.subscription == "1" %>
           <span class="badge bg-warning text-dark border border-warning fs-6">+ KES 2,900/mo (12-Month Contract)</span>
        <% else %>
           <p class="lead">
             Or just <strong><%= number_to_currency((@quote.total_amount.to_i / 365), unit: "KES ", precision: 0) %>/day</strong>
             <span class="badge bg-light text-dark border ms-2">Less than lunch</span>
           </p>
        <% end %>
      </div>

      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card shadow-lg border-0 text-center p-5 bg-white rounded-3">
            <div class="mb-4">
              <i class="bi bi-file-earmark-lock2-fill text-warning display-1"></i>
            </div>
            <h3 class="fw-bold mb-3">Unlock Your Technical Breakdown</h3>
            <p class="text-muted mb-4">
              To protect our proprietary system design, the full itemized list is locked.
            </p>
            <a href="https://wa.me/254111770786?text=Hi, Quote Ref <%= @quote.id %>. Can I see the breakdown?" class="btn btn-success btn-lg w-100 py-3 fw-bold shadow-sm hover-lift">
              <i class="bi bi-whatsapp me-2"></i> Get Full Breakdown on WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div class="mt-5 pt-5 border-top">
        <div class="text-center mb-5">
          <h3 class="fw-bold text-dark">Complete Your Security Grid</h3>
        </div>

        <div class="row g-4">
           <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden text-white" style="background: linear-gradient(45deg, #0e2a5c, #1a4a8d);">
              <div class="card-body p-4 d-flex flex-column flex-md-row align-items-center justify-content-between">
                <div class="mb-3 mb-md-0 text-center text-md-start">
                  <h3 class="fw-bold mb-1"><i class="bi bi-shield-shaded me-2"></i>Manned Guarding Services</h3>
                  <p class="mb-0 text-white-50">Vetted, Uniformed & Trained Security Officers.</p>
                </div>
                <a href="https://wa.me/254111770786?text=Hi, regarding Quote Ref <%= @quote.id %>. Interested in Guards." class="btn btn-warning fw-bold px-4 py-2 shadow hover-lift text-dark">
                  Get Guard Quote
                </a>
              </div>
            </div>
          </div>
          
          <div class="col-md-4 col-6">
            <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
              <i class="bi bi-fingerprint text-danger display-6 mb-2"></i>
              <h6 class="fw-bold">Access Control</h6>
            </div>
          </div>
          <div class="col-md-4 col-6">
            <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
              <i class="bi bi-door-open text-danger display-6 mb-2"></i>
              <h6 class="fw-bold">Video Intercoms</h6>
            </div>
          </div>
          <div class="col-md-4 col-6">
            <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
              <i class="bi bi-bell-fill text-danger display-6 mb-2"></i>
              <h6 class="fw-bold">Smart Alarms</h6>
            </div>
          </div>

        </div>
      </div>
    </div>
  <% end %> <style>
    .hover-card { transition: transform 0.2s; }
    .hover-card:hover { transform: translateY(-5px); border-color: #dc3545 !important; }
    .hover-lift:hover { transform: translateY(-2px); }
  </style>

<% end %>