<div class="container my-5">
  
  <div class="text-center mb-5">
    <h5 class="text-muted text-uppercase ls-2">Estimated Investment</h5>
    <h1 class="text-success display-3 fw-bold my-3">
      <%= number_to_currency(@quote.total_amount, unit: "KES ", precision: 0) %>
    </h1>
    <p class="lead">
      Or just <strong><%= number_to_currency((@quote.total_amount.to_i / 365), unit: "KES ", precision: 0) %>/day</strong>
      <span class="badge bg-light text-dark border ms-2">Less than lunch</span>
    </p>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-lg border-0 text-center p-5 bg-white rounded-3">
        <div class="mb-4">
          <i class="bi bi-file-earmark-lock2-fill text-warning display-1"></i>
        </div>
        <h3 class="fw-bold mb-3">Unlock Your Technical Breakdown</h3>
        <p class="text-muted mb-4">
          To protect our proprietary system design, the full itemized list (camera models, DVR specs, and cabling plan) is locked.
        </p>
        <p class="mb-4">
          <strong>Click below to receive the official PDF breakdown via WhatsApp immediately.</strong>
        </p>
        
        <a href="https://wa.me/254757617084?text=Hi, I just generated Quote #<%= @quote.id %> for KES <%= @quote.total_amount %>. Can I see the full breakdown?" class="btn btn-success btn-lg w-100 py-3 fw-bold shadow-sm hover-lift">
          <i class="bi bi-whatsapp me-2"></i> Get Full Breakdown on WhatsApp
        </a>
        
        <div class="mt-3 text-muted small">
          <i class="bi bi-shield-check"></i> No spam. Direct connection to a Security Engineer.
        </div>
      </div>
    </div>
  </div>

  <div class="mt-5 pt-5 border-top">
    <div class="text-center mb-5">
      <h3 class="fw-bold text-dark">Complete Your Security Grid</h3>
      <p class="text-muted">Urban Eye is your single point of contact for integrated facility systems.</p>
    </div>

    <div class="row g-4">
      
      <div class="col-12"><h5 class="text-uppercase text-danger border-bottom pb-2">Physical Security & Access</h5></div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-fingerprint text-danger display-6 mb-2"></i>
          <h6 class="fw-bold">Access Control</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Access Control." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-door-open text-danger display-6 mb-2"></i>
          <h6 class="fw-bold">Video Intercoms</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Video Intercoms." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-bell-fill text-danger display-6 mb-2"></i>
          <h6 class="fw-bold">Smart Alarms</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Ajax Alarms." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-12 mt-4"><h5 class="text-uppercase text-primary border-bottom pb-2">Network Infrastructure</h5></div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-hdd-network text-primary display-6 mb-2"></i>
          <h6 class="fw-bold">Structured Cabling</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Cabling." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-router text-primary display-6 mb-2"></i>
          <h6 class="fw-bold">Enterprise WiFi</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Enterprise WiFi." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-activity text-primary display-6 mb-2"></i>
          <h6 class="fw-bold">Fiber Optics</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Fiber Optics." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-12 mt-4"><h5 class="text-uppercase text-success border-bottom pb-2">Advanced Connectivity</h5></div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-telephone-inbound text-success display-6 mb-2"></i>
          <h6 class="fw-bold">VoIP Systems</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in VoIP." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-reception-4 text-success display-6 mb-2"></i>
          <h6 class="fw-bold">Signal Boosting</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Signal Boosting." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

      <div class="col-md-4 col-6">
        <div class="p-3 border rounded h-100 text-center bg-white shadow-sm hover-card">
          <i class="bi bi-speaker text-success display-6 mb-2"></i>
          <h6 class="fw-bold">Audio & Video</h6>
          <a href="https://wa.me/254757617084?text=Hi, regarding Quote #<%= @quote.id %>. I am interested in Audio/Video." class="btn btn-sm btn-outline-dark w-100 stretched-link">Inquire</a>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* Subtle hover effect for the service cards */
  .hover-card { transition: transform 0.2s; }
  .hover-card:hover { transform: translateY(-5px); border-color: #dc3545 !important; }
  .hover-lift:hover { transform: translateY(-2px); }
</style>