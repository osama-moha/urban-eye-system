<div class="container mt-5 mb-5">
  <div class="card shadow-lg border-0" style="max-width: 850px; margin: auto; position: relative; overflow: hidden;">
    
    <div class="pdf-watermark">
      <%= image_tag "logo.png" %>
    </div>

    <div class="quote-header" style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #eaeaea; padding: 40px 40px 20px 40px; position: relative; z-index: 2; background: white;">
      <div style="flex: 0 0 250px;">
        <%= image_tag "logo.png", class: "brand-logo", style: "width: 100%; height: auto; display: block;" %>
      </div>

      <div style="flex: 1; text-align: right; padding-left: 20px;">
        <h1 class="doc-title" style="color: #003366; font-weight: 800; font-size: 32px; margin: 0 0 10px 0; text-transform: uppercase;">Quotation</h1>
        <table style="float: right; text-align: right; font-size: 14px;">
          <tr>
            <td style="color: #666; padding-right: 10px;">Date:</td>
            <td style="font-weight: bold; color: #000;"><%= Date.today.strftime("%d/%m/%Y") %></td>
          </tr>
          <tr>
            <td style="color: #666; padding-right: 10px;">Ref #:</td>
            <td style="font-weight: bold; color: #000;">UES/2025/QT-<%= @quote.id.to_s.rjust(4, '0') %></td>
          </tr>
          <tr>
            <td style="color: #666; padding-right: 10px;">To:</td>
            <td style="font-weight: bold; color: #000;"><%= @quote.email.presence || "Valued Client" %></td>
          </tr>
        </table>
      </div>
    </div>

    <div class="card-body p-5" style="position: relative; z-index: 1;">
      
      <div class="row mb-4">
        <div class="col-md-12">
          <div class="alert alert-light border-start border-5 border-primary shadow-sm p-4" style="border-color: #003366 !important;">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h5 class="fw-bold mb-1" style="color: #003366;">
                  <i class="bi bi-shield-check text-success"></i> Peace of Mind Investment
                </h5>
                <p class="text-muted mb-0 small">
                  Based on a 1-year operational cycle, this security grid costs just:
                </p>
              </div>
              <div class="text-end">
                <h2 class="text-success fw-bold mb-0">
                  KES <%= number_with_delimiter((@quote.total_amount.to_i / 365).to_i) %>/day
                </h2>
                <span class="badge bg-success bg-opacity-10 text-success">Less than lunch</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 mb-4">
        <h6 class="fw-bold text-uppercase border-bottom pb-2" style="color: #003366;">
          <i class="bi bi-geo-alt-fill"></i> Site-Specific Strategy: <%= @quote.building_type %>
        </h6>
        <div class="bg-white p-3 border rounded">
          <p class="small text-muted mb-2">
            Based on your location in <strong><%= @quote.location.presence || "Nairobi" %></strong>, we have configured this system to address:
          </p>
          <ul class="small mb-0 text-dark">
            <% if @quote.building_type == "Commercial / Office" %>
              <li><strong>Internal Shrinkage:</strong> Coverage of POS and stock areas to reduce theft.</li>
              <li><strong>Liability Defense:</strong> 14+ day recording retention for dispute resolution.</li>
            <% elsif @quote.building_type == "Industrial / Warehouse" %>
              <li><strong>Perimeter Control:</strong> Long-range monitoring for unlit yards/gates.</li>
              <li><strong>Safety Compliance:</strong> Monitoring of loading bays and hazardous zones.</li>
            <% else %>
              <li><strong>Perimeter Defense:</strong> Deterrence of opportunistic entry at main gates.</li>
              <li><strong>Domestic Oversight:</strong> Clear monitoring of service areas and staff.</li>
            <% end %>
          </ul>
        </div>
      </div>
      
      <div class="text-center mb-4">
        <h5 class="fw-bold bg-light p-2 border rounded">
          <%= @quote.camera_count %>-CAMERA SYSTEM (SUPPLY & INSTALL)
        </h5>
      </div>

      <table class="table table-bordered align-middle" style="background: transparent !important;">
        <thead class="table-dark text-center">
          <tr>
            <th scope="col" style="width: 55%;">Item Description</th>
            <th scope="col" style="width: 15%;">Qty</th>
            <th scope="col" style="width: 30%;">Total (KES)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <strong>Hikvision Turbo HD Hardware Kit</strong>
              <ul class="small text-muted mb-0 mt-1 ps-3">
                <li>
                  <% if @indoor_count.to_i > 0 || @outdoor_count.to_i > 0 %>
                    <% if @indoor_count.to_i > 0 %><%= @indoor_count %>x Indoor Turret<% end %>
                    <% if @indoor_count.to_i > 0 && @outdoor_count.to_i > 0 %> / <% end %>
                    <% if @outdoor_count.to_i > 0 %><%= @outdoor_count %>x Outdoor Bullet<% end %>
                  <% else %>
                    <%= @quote.camera_count %>x Hikvision HD Cameras
                  <% end %>
                  <span class="text-muted small">(2MP/4MP)</span>
                </li>
                <li><%= @dvr_name %> (Remote View Ready)</li>
                <li><strong><%= @hdd_name %></strong> (For <%= @quote.recording_days %> days recording)</li>
                <li>Central Power Supply Unit (12V)</li>
                <% if @quote.monitor? %><li>19-inch Surveillance Monitor included</li><% end %>
                <% if @quote.ups? %><li>650VA Power Backup included</li><% end %>
              </ul>
            </td>
            <td class="text-center">1 Set</td>
            <td class="text-end fw-bold"><%= number_to_currency(@hardware, unit: "", precision: 0) %></td>
          </tr>

          <tr>
            <td>
              <strong>Cabling & Installation Infrastructure</strong>
              <ul class="small text-muted mb-0 mt-1 ps-3">
                <li>Cat6 UTP Cabling (Premium Copper)</li>
                <li>Video Baluns & DC Power Connectors</li>
                <li>Junction Boxes & Mounting Accessories</li>
                <li>Trunking, Conduit & Consumables</li>
              </ul>
            </td>
            <td class="text-center">1 Lot</td>
            <td class="text-end fw-bold"><%= number_to_currency(@infrastructure, unit: "", precision: 0) %></td>
          </tr>

          <tr>
            <td>
              <strong>Professional Labor & Configuration</strong>
              <ul class="small text-muted mb-0 mt-1 ps-3">
                <li>Drilling & Mounting across <%= @quote.floors %> floors</li>
                <li>Cable laying & Termination</li>
                <li>DVR Configuration & Mobile App Setup</li>
                <li>User Training</li>
              </ul>
            </td>
            <td class="text-center">1 Lot</td>
            <td class="text-end fw-bold"><%= number_to_currency(@labor, unit: "", precision: 0) %></td>
          </tr>

          <tr style="border-top: 3px solid #000;">
            <td colspan="3" style="padding: 0;">
              <div class="print-color" style="background-color: #003366 !important; -webkit-print-color-adjust: exact; color: white; padding: 20px; display: flex; justify-content: center; align-items: center; gap: 20px;">
                <span style="font-size: 18px; text-transform: uppercase; letter-spacing: 1px; font-weight: normal;">
                  Grand Total (KES):
                </span>
                <span style="font-size: 32px; font-weight: 800;">
                  <%= number_to_currency(@quote.total_amount.present? ? @quote.total_amount : @min, unit: "KES ", precision: 0) %>
                </span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>

      <div class="mt-5 p-4 bg-light rounded border keep-together">
        <h6 class="fw-bold text-decoration-underline">Terms & Conditions</h6>
        <ol class="small text-muted mb-0 ps-3">
          <li><strong>Payment:</strong> 70% Deposit required to commence work. 30% on completion.</li>
          <li><strong>Validity:</strong> Quote valid for 14 Days.</li>
          <li><strong>Warranty:</strong> 1 Year Warranty on Hardware (Cameras/DVR).</li>
          <li><strong>Note:</strong> Final price may vary slightly after detailed site survey.</li>
        </ol>
      </div>

      <div class="mt-5" style="display: flex; justify-content: space-between; align-items: flex-end; padding: 0 10px;">
        <div style="flex: 0 0 250px; text-align: left;">
          <p class="small text-muted mb-1">Issued By:</p>
          <div style="border-bottom: 1px solid #000; height: 60px; margin-bottom: 5px; position: relative;">
            <span style="position: absolute; bottom: 5px; left: 0; font-family: 'cursive'; color: #003366; font-size: 14px;">
              Urban Eye Security Admin
            </span>
          </div>
          <p class="fw-bold small mb-0">Authorized Signature</p>
        </div>

        <div style="flex: 0 0 250px; text-align: left;">
          <p class="small text-muted mb-1">Approved By (Client):</p>
          <div style="border-bottom: 1px solid #000; height: 60px; margin-bottom: 5px;"></div>
          <p class="fw-bold small mb-0">Signature & Date</p>
        </div>
      </div>

      <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-5 d-print-none">
        
        <button onclick="window.print()" class="btn btn-dark btn-lg px-4">
          <i class="bi bi-printer"></i> Print / Save PDF
        </button>

        <% 
           quote_id_formatted = @quote.id.to_s.rjust(4, '0')
           current_total = @quote.total_amount || 0
           expiry_date = (Date.today + 7.days).strftime("%d %b")
           
           whatsapp_message = "Hi Urban Eye, I am reviewing the Guardian System Proposal (Ref: UES-#{quote_id_formatted}). I see the price lock for KES #{number_with_delimiter(current_total.to_i)} expires on #{expiry_date}. Is the installation slot for next week still open?" 
           
           whatsapp_url = "https://wa.me/254111770786?text=#{URI.encode_www_form_component(whatsapp_message)}" 
        %>

        <a href="<%= whatsapp_url %>" class="btn btn-success btn-lg px-4 shadow" target="_blank">
          <i class="bi bi-whatsapp"></i> Secure This Price
        </a>

      </div>

    </div>
  </div>
</div>