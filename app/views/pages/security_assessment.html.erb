<% content_for :title, "Urban Eye Security — 2-Minute Security Assessment" %>

<section class="assessment-hero text-white">
  <div class="container py-5">
    <div class="row">
      <div class="col-lg-8">
        <span class="badge bg-danger text-uppercase mb-3 px-3 py-2">
          Free Security Assessment
        </span>

        <h1 class="display-5 fw-bold mb-3">
          2-Minute Security Assessment
        </h1>

        <p class="lead mb-0" style="max-width: 760px;">
          Complete this short assessment so our team can understand your property,
          security needs, and recommend the most suitable protection plan.
          No obligation. No pressure.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="py-5 assessment-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="assessment-intro mb-4">
          <h2 class="h4 fw-bold mb-2">
            Tell us what you need protected
          </h2>

          <p class="text-muted mb-0">
            Your answers help us prepare a better proposal before we contact you.
          </p>
        </div>

        <div class="google-form-wrapper">
          <iframe
            src="https://docs.google.com/forms/d/e/1FAIpQLSfLi2YbLtoNFWD54J8hT8wL12aZZoc4pIRT-cIyXXf5WWCEhA/viewform?embedded=true"
            width="100%"
            height="1450"
            frameborder="0"
            marginheight="0"
            marginwidth="0">
            Loading…
          </iframe>
        </div>

        <div class="text-center mt-4">
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSfLi2YbLtoNFWD54J8hT8wL12aZZoc4pIRT-cIyXXf5WWCEhA/viewform"
            target="_blank"
            rel="noopener"
            class="btn btn-outline-primary fw-bold px-4">
            Open Form in New Tab
          </a>
        </div>

        <div class="text-center mt-4">
          <p class="text-muted small mb-2">
            Need urgent assistance?
          </p>

          <a
            href="https://wa.me/254714007114"
            class="btn btn-success fw-bold px-4 py-2"
            target="_blank"
            rel="noopener">
            <i class="bi bi-whatsapp me-2"></i>
            WhatsApp Urban Eye Security
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .assessment-hero {
    background: #1B2C6E;
  }

  .assessment-section {
    background: #F2F4F7;
  }

  .assessment-intro {
    background: #ffffff;
    border-left: 5px solid #C4272E;
    padding: 1.5rem;
    border-radius: 8px;
  }

  .assessment-intro h2 {
    color: #1B2C6E;
  }

  .google-form-wrapper {
    background: #ffffff;
    border: 1px solid #D9DEE8;
    border-radius: 8px;
    overflow: hidden;
  }

  .google-form-wrapper iframe {
    display: block;
    width: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .google-form-wrapper iframe {
      height: 1650px;
    }
  }
</style>