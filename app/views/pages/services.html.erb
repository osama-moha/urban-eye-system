<div id="services" class="bg-dark text-white py-5 mb-5" style="background: linear-gradient(180deg, #0e2a5c 0%, #001a33 100%);">
  <div class="container text-center">
    <h1 class="fw-bold display-4">Our Expertise</h1>
    <p class="lead text-white-50">Comprehensive Security & Network Solutions for 2025</p>
  </div>
</div>

<div class="container mb-5">
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold text-uppercase" style="color: #000000; border-bottom: 3px solid #d92e2e; display: inline-block; padding-bottom: 5px;">
        Security Systems & Technology
      </h3>
      <p class="text-muted">Advanced hardware solutions for automated protection.</p>
    </div>
  </div>

  <div class="row g-4">
    
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift overflow-hidden">
        <%= image_tag "services/cctv.webp", class: "card-img-top", alt: "CCTV Camera System", style: "height: 200px; object-fit: cover;" %>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">CCTV Surveillance</h4>
          <p class="text-muted small">High-definition IP and Analog camera systems. Remote viewing via mobile app, motion detection, and extended recording retention.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <%= link_to "Instant Estimator", root_path, class: "btn btn-danger fw-bold w-75" %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift">
        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="height: 200px;">
          <i class="bi bi-fingerprint display-1 text-primary"></i>
        </div>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">Biometric Access</h4>
          <p class="text-muted small">Fingerprint, RFID card, and Face ID systems. Track employee attendance and restrict access to sensitive server rooms.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <button type="button" class="btn btn-outline-dark w-100" 
            data-bs-toggle="modal" 
            data-bs-target="#inquiryModal" 
            data-service="Biometric Access Systems">
            Inquire Now
          </button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift">
        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="height: 200px;">
          <i class="bi bi-lightning-charge display-1 text-warning"></i>
        </div>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">Electric Fencing</h4>
          <p class="text-muted small">Top-wall razor wire with intelligent energizers. Triggers instant alarms upon cutting or tampering. Essential for perimeter defense.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <button type="button" class="btn btn-outline-dark w-100" 
            data-bs-toggle="modal" 
            data-bs-target="#inquiryModal" 
            data-service="Electric Fencing">
            Get Fencing Quote
          </button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift">
        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="height: 200px;">
          <i class="bi bi-router display-1 text-info"></i>
        </div>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">Enterprise WiFi</h4>
          <p class="text-muted small">Long-range Ubiquiti Access Points and structured cabling. Seamless roaming for offices, hotels, and large homes.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <button type="button" class="btn btn-outline-dark w-100" 
            data-bs-toggle="modal" 
            data-bs-target="#inquiryModal" 
            data-service="Enterprise WiFi">
            Get WiFi Quote
          </button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift">
        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="height: 200px;">
          <i class="bi bi-door-open display-1 text-success"></i>
        </div>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">Video Intercoms</h4>
          <p class="text-muted small">See who is at the gate before you open. Video confirmation and remote unlocking via mobile app.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <button type="button" class="btn btn-outline-dark w-100" 
            data-bs-toggle="modal" 
            data-bs-target="#inquiryModal" 
            data-service="Video Intercom Systems">
            Request Intercom Quote
          </button>
        </div>
      </div>
    </div>

  </div>
</div>

<div class="container mb-5">
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold text-uppercase" style="color: #000000; border-bottom: 3px solid #d92e2e; display: inline-block; padding-bottom: 5px;">
        Manned Security Services
      </h3>
      <p class="text-muted">Highly trained officers for physical protection.</p>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm hover-lift overflow-hidden">
        <%= image_tag "services/guarding.jpg", class: "card-img-top", alt: "Professional Security Guards", style: "height: 200px; object-fit: cover;" %>
        <div class="card-body p-4 text-center">
          <h4 class="fw-bold text-navy">Manned Guarding</h4>
          <p class="text-muted small">Vetted, uniformed, and highly trained security officers for commercial and residential properties. 24/7 supervision and rapid response backup.</p>
        </div>
        <div class="card-footer bg-white border-0 pb-4 text-center">
          <button type="button" class="btn btn-dark w-100" 
            data-bs-toggle="modal" 
            data-bs-target="#inquiryModal" 
            data-service="Manned Guarding">
            Request Guard Services
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .text-navy { color: #0e2a5c; }
  .hover-lift { transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .hover-lift:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
</style>

<div class="modal fade" id="inquiryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title">Get a Quote for <span id="service-name-span" class="text-warning">Services</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <div class="modal-body">
        <%= form_with model: Quote.new, url: quotes_path, local: true do |f| %>
          
          <%= f.hidden_field :building_type, id: "hidden-interest-field" %>
          <%= f.hidden_field :camera_count, value: 0 %>
          
          <div class="mb-3">
            <label class="form-label">Your Name</label>
            <%= f.text_field :name, class: "form-control", required: true, placeholder: "John Doe" %>
          </div>

          <div class="mb-3">
            <label class="form-label">Phone Number (WhatsApp)</label>
            <%= f.text_field :whatsapp_number, class: "form-control", required: true, placeholder: "0712 345 678" %>
          </div>

          <div class="mb-3">
            <label class="form-label">Location</label>
            <%= f.text_field :location, class: "form-control", required: true, placeholder: "e.g. Westlands, Nairobi" %>
          </div>
          
          <div class="mb-3">
            <label class="form-label">Specific Requirements (Optional)</label>
            <%= f.text_area :purpose, class: "form-control", rows: 3, placeholder: "Describe what you need..." %>
          </div>

          <div class="d-grid">
            <%= f.submit "Request Quote", class: "btn btn-danger btn-lg" %>
          </div>
          
          <p class="text-center small text-muted mt-2">
            <i class="fas fa-lock"></i> Your details are sent securely to our team.
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var inquiryModal = document.getElementById('inquiryModal');
    
    inquiryModal.addEventListener('show.bs.modal', function (event) {
      // Button that triggered the modal
      var button = event.relatedTarget;
      
      // Extract info from data-service attribute
      var serviceName = button.getAttribute('data-service');
      
      // Update the Modal Title
      var modalTitle = inquiryModal.querySelector('#service-name-span');
      modalTitle.textContent = serviceName;
      
      // Update the Hidden Field (so it saves to database as "Interest")
      var hiddenInput = inquiryModal.querySelector('#hidden-interest-field');
      hiddenInput.value = serviceName;
    });
  });
</script>