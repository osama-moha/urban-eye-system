<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  </head>
  <body style="background-color: #f8f9fa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; padding: 20px;">
    
    <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 0.375rem; overflow: hidden;">
      
      <div style="background-color: #0d6efd; padding: 1rem 1.5rem; color: white;">
        <h2 style="margin: 0; font-size: 1.5rem; font-weight: 500;">
          🔔 New Quote Alert
        </h2>
      </div>

      <div style="padding: 1.5rem;">
        
        <p style="color: #6c757d; font-size: 0.875rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">
          Client Details
        </p>
        
        <div style="margin-bottom: 1.5rem;">
          <p style="margin: 5px 0; font-size: 16px;">
            <strong>📱 Phone:</strong> <%= @quote.lead.phone %>
          </p>
          <% if @quote.lead.email.present? %>
            <p style="margin: 5px 0; font-size: 16px;">
              <strong>📧 Email:</strong> <%= @quote.lead.email %>
            </p>
          <% end %>
        </div>

        <hr style="border: 0; border-top: 1px solid #dee2e6; margin: 1.5rem 0;">

        <p style="color: #6c757d; font-size: 0.875rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">
          Project Scope
        </p>

        <table style="width: 100%; margin-bottom: 1.5rem; border-collapse: collapse;">
          <tr>
            <td style="padding: 8px 0;"><strong>🏢 Building:</strong></td>
            <td style="text-align: right;"><%= @quote.building_type %></td>
          </tr>
          <tr>
            <td style="padding: 8px 0;"><strong>🎥 Cameras:</strong></td>
            <td style="text-align: right;"><%= @quote.camera_count %></td>
          </tr>
          <tr>
            <td style="padding: 8px 0;"><strong>🧱 Floors:</strong></td>
            <td style="text-align: right;"><%= @quote.floors %></td>
          </tr>
           <tr>
            <td style="padding: 8px 0;"><strong>⏳ Timeline:</strong></td>
            <td style="text-align: right;"><%= @quote.timeline %></td>
          </tr>
        </table>

        <div style="background-color: #d1e7dd; color: #0f5132; padding: 1rem; border-radius: 0.25rem; text-align: center; margin-bottom: 1.5rem;">
          <span style="font-size: 0.9rem;">Estimated Total</span><br>
          <strong style="font-size: 1.75rem;">KES <%= number_with_delimiter(@quote.total_amount.to_i) %></strong>
        </div>

        <div style="text-align: center;">
          <a href="<%= quote_url(@quote) %>" style="display: inline-block; background-color: #0d6efd; color: white; padding: 10px 20px; text-decoration: none; border-radius: 0.375rem; font-weight: bold;">
            View Full Quote in Admin
          </a>
        </div>

      </div>
      
      <div style="background-color: #f8f9fa; padding: 1rem; text-align: center; font-size: 0.8rem; color: #6c757d; border-top: 1px solid #dee2e6;">
        Generated by Urban Eye Estimator
      </div>

    </div>
  </body>
</html>