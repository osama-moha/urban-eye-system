<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Urban Eye Estimator" %></title>
    <%= favicon_link_tag 'logo.png', type: 'image/png' %>
<%= favicon_link_tag 'logo.png', rel: 'apple-touch-icon', type: 'image/png' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <style>
  /* === MOBILE FIXES === */
  @media (max-width: 768px) {
    /* 1. Stop the whole page from sliding left/right */
    html, body {
      overflow-x: hidden;
      width: 100%;
    }
    
    .container {
      padding-left: 5px !important;
      padding-right: 5px !important;
      max-width: 100% !important;
    }

    /* 2. Fix the "Peace of Mind" Box & Grand Total Box */
    .card, .border, .shadow-sm, .alert {
      width: 100% !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      box-sizing: border-box !important; /* Includes padding in width */
    }

    /* 3. Fix the Red Button Text */
    .btn {
      white-space: normal !important; /* Wrap text */
      font-size: 14px !important;     /* Smaller text */
      padding: 10px 5px !important;
      width: 100% !important;
      display: block;
    }

    /* 4. Tame the Table */
    /* This forces the table to scroll sideways INSIDE its box, 
       instead of stretching the whole page */
    .table-responsive {
      display: block;
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    
    /* Make table text tiny so more fits */
    table td, table th {
      font-size: 11px !important; 
      padding: 4px !important;
    }
  }

  /* === PDF / PRINT FIXES === */
  @media print {
    @page {
      size: A4;
      margin: 5mm; /* Very small margins to fit more */
    }

    body {
      /* Shrink EVERYTHING by 10% to fit on paper */
      zoom: 0.9; 
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      background-color: white !important;
    }

    /* Hide web-only junk */
    .btn, .navbar, footer, .no-print {
      display: none !important;
    }

    /* Force layouts to be full width */
    .container, .row, .col-md-6, .card {
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      float: none !important;
      border: 1px solid #ddd !important; /* Add thin borders so it looks like a document */
    }

    /* Stop page breaks inside rows */
    tr {
      page-break-inside: avoid;
    }
  }
</style>
  </head>

  <body class="bg-light">
    
    <% if system_admin_signed_in? %>
      <nav class="navbar navbar-dark bg-dark px-4 mb-4 shadow-sm">
        <div class="container-fluid">
          <span class="navbar-brand mb-0 h1 fw-bold" style="font-size: 1rem;">
            <i class="bi bi-shield-lock-fill me-2"></i>Urban Eye System
          </span>
          
          <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small">
              Signed in as: <strong><%= current_system_admin.email %></strong>
            </span>
            
            <%= link_to destroy_system_admin_session_path, data: { turbo_method: :delete }, class: "btn btn-danger btn-sm py-1 px-3" do %>
              Log Out
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>

    <%= yield %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>
