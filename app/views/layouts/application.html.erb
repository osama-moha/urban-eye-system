<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Urban Eye Estimator" %></title>
    <%= favicon_link_tag 'logo.png' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <style>
  /* 1. GENERAL MOBILE FIXES */
  @media (max-width: 768px) {
    .container {
      width: 100% !important;
      padding-left: 10px !important;
      padding-right: 10px !important;
      overflow-x: hidden; /* Stop horizontal scrolling */
    }

    /* Fix the "Peace of Mind" box width */
    .card, .border, .shadow-sm {
      width: 100% !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }

    /* Make text smaller on phone so tables fit */
    body, table, th, td {
      font-size: 14px !important;
    }

    /* Fix the Red Button cutting off */
    .btn {
      white-space: normal !important;
      height: auto !important;
      padding: 12px 10px !important;
      width: 100% !important;
      display: block;
      margin-bottom: 10px;
    }
    
    /* Allow tables to scroll sideways if they are still too big */
    .table-responsive {
      display: block;
      width: 100%;
      overflow-x: auto;
    }
  }

  /* 2. PDF / PRINTING FIXES */
  @media print {
    /* Hide buttons and navigation when printing */
    .btn, button, .navbar, .no-print, header, footer {
      display: none !important;
    }

    /* Force background colors to show up (otherwise logos/headers look white) */
    body {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      background: white !important;
    }

    /* Reset widths for paper size */
    .container, .card, .row {
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      box-shadow: none !important;
      border: none !important;
    }

    /* Ensure text is black and sharp */
    body, p, td, li {
      color: #000 !important;
    }

    /* Prevent page breaks inside important elements */
    tr, img, .card {
      page-break-inside: avoid;
    }

    /* Use standard page margins */
    @page {
      margin: 1cm;
      size: auto;
    }
  }
</style>
  </head>

  <body class="bg-light">
    
    <% if system_admin_signed_in? %>
      <nav class="navbar navbar-dark bg-dark px-4 mb-4 shadow-sm">
        <div class="container-fluid">
          <span class="navbar-brand mb-0 h1 fw-bold" style="font-size: 1rem;">
            <i class="bi bi-shield-lock-fill me-2"></i>Urban Eye System
          </span>
          
          <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small">
              Signed in as: <strong><%= current_system_admin.email %></strong>
            </span>
            
            <%= link_to destroy_system_admin_session_path, data: { turbo_method: :delete }, class: "btn btn-danger btn-sm py-1 px-3" do %>
              Log Out
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>

    <%= yield %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>
